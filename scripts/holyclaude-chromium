#!/bin/sh
set -eu

BROWSER_BIN="${HOLYCLAUDE_CHROMIUM_BINARY:-/usr/lib/chromium/chromium}"

if [ ! -x "$BROWSER_BIN" ]; then
    echo "holyclaude-chromium: Debian Chromium executable not found at $BROWSER_BIN" >&2
    exit 127
fi

# CHROMIUM_FLAGS is intentionally split like Debian's chromium launcher flags.
# shellcheck disable=SC2086
exec "$BROWSER_BIN" ${CHROMIUM_FLAGS:-} "$@"
