#!/bin/sh
set -eu

BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH:-/ms-playwright}"
BROWSER_BIN=""

for candidate in "$BROWSERS_PATH"/chromium-*/chrome-linux*/chrome; do
    if [ -x "$candidate" ]; then
        BROWSER_BIN="$candidate"
        break
    fi
done

if [ -z "$BROWSER_BIN" ]; then
    echo "holyclaude-chromium: Playwright Chromium executable not found under $BROWSERS_PATH/chromium-*/chrome-linux*/chrome" >&2
    exit 127
fi

# CHROMIUM_FLAGS is intentionally split like Debian's chromium launcher flags.
# shellcheck disable=SC2086
exec "$BROWSER_BIN" ${CHROMIUM_FLAGS:-} "$@"
